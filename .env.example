# Copy this to .env and fill in your values
# NEVER commit .env to git

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Pinecone (https://app.pinecone.io)
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_HOST=https://your-index-name-xxxx.svc.pinecone.io

# Tally form embed URL
# In Tally: Share → Embed → copy the src URL
TALLY_FORM_URL=https://tally.so/embed/YOUR_FORM_ID?alignLeft=1&hideTitle=1&transparentBackground=1
